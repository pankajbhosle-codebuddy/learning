generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url= env("MONGO_URI")
}

model books {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  v           Int      @default(0)

  title       String
  description String

  authorId    String   @db.ObjectId
  author      users    @relation(fields: [authorId], references: [id])

  genreIds    String[] @db.ObjectId
  genres      genres[] @relation(fields: [genreIds], references: [id])

  createdAt   DateTime @db.Date @default(now())
  updatedAt   DateTime @db.Date @updatedAt

  @@map("books")
}

model genres {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  v         Int      @map("__v") @default(0)

  name      String   @unique

  bookIds   String[] @db.ObjectId
  books     books[]  @relation(fields: [bookIds], references: [id])

  createdAt DateTime @db.Date @default(now())
  updatedAt DateTime @db.Date @updatedAt

  @@map("genres")
}

model tokens {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  v         Int      @map("__v") @default(0)

  token     String
  expiresIn DateTime @db.Date

  userId    String   @db.ObjectId
  user      users    @relation(fields: [userId], references: [id])

  createdAt DateTime @db.Date @default(now())
  updatedAt DateTime @db.Date @updatedAt

  @@map("tokens")
}

model users {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  v         Int      @map("__v") @default(0)

  username  String   @unique
  password  String
  isAuthor  Boolean  @default(false)

  books     books[]
  tokens    tokens[]

  createdAt DateTime @db.Date @default(now())
  updatedAt DateTime @db.Date @updatedAt

  @@map("users")
}